    {
      "id": "XMzeG5L24p2l0mStDkmi9",
      "type": "text",
      "x": 1339.5254079381139,
      "y": 23.024245492273394,
      "width": 526.4791870117188,
      "height": 320,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
